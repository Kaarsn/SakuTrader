# AI API Configuration
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# News Configuration - THREE OPTIONS (all optional):
# 
# 1️⃣ FALLBACK NEWS (FREE - ACTIVE BY DEFAULT)
#    - Generated realistic news with sentiment
#    - No API key needed
#    - Working out of the box
#
# 2️⃣ NewsAPI (PAID - Optional upgrade)
#    - Real news from worldwide sources
#    - Get free key: https://newsapi.org (limited to 100 req/day free tier)
#    - Paid plans start $25/month for production
#    - Set NEWS_API_KEY below for real news
#
# 3️⃣ RSS FEEDS (FREE - Beta, needs fixing)
#    - Real news from Indonesian portals
#    - May require RSS URL updates if portals change
#    - Currently configured to try RSS first, then fallback
#
NEWS_API_KEY=

# Security
JWT_SECRET=your-jwt-secret-key-change-this

# Analytics Service
# LOCAL: http://localhost:8000
# RAILWAY: http://analytics:8000
ANALYTICS_SERVICE_URL=http://localhost:8000

# Server
PORT=4000
